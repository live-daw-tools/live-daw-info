{
	"name": "@live-daw-tools/live-daw-info",
	"version": "0.0.1",
	"description": "A library for retrieving information about the user's Live installation(s).",
	"main": "index.js",
	"scripts": {
		"test": "vitest",
		"watch": "vitest --watch",
		"coverage:macos": "vitest run --coverage --coverage.exclude=./lib/ableton-info-win64.js",
		"coverage:windows": "vitest run --coverage --coverage.exclude=./lib/ableton-info-macos.js",
		"publish": "npm publish --access=public"
	},
	"keywords": [],
	"author": "Jeff Griffiths (  https://github.com/jeffgca )",
	"license": "ISC",
	"type": "module",
	"devDependencies": {
		"@vitest/coverage-v8": "^2.0.0",
		"nodemon": "^3.1.11",
		"vitest": "^2.0.0"
	},
	"dependencies": {
		"dotenv": "^16.6.1",
		"lodash-es": "^4.17.22",
		"yargs": "^18.0.0"
	}
}
